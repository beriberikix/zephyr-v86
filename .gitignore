# Zephyr build artifacts
firmware/.west/
firmware/build/
firmware/CMakeFiles/
firmware/CMakeCache.txt
firmware/cmake_install.cmake
build/

# Build output
*.elf
*.bin
*.hex
*.o
*.a

# Vendor BIOS blobs in web/lib are essential for the emulator — override above
!web/lib/*.bin

# IDE and editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Web dev dependencies and artifacts
# Note: web/lib/ is committed (contains essential vendor libraries for emulator)
# But specific artifacts/builds are ignored:
web/node_modules/
web/zephyr.elf
web/zephyr.exe
web/v86-*.bin
web/v86-rootfs.cpio.xz
web/*.sha256

# Nested/vendor repositories
modules/
zephyr/

# RootlessRelay local clone
.relay/

# Python cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage

# Environment files
.env
.env.local

# Temporary files
*.tmp
*.temp
